  }, null)
}
/**
 * 设置背景模糊
 */
export function setVirtualBackground(enable: Boolean) {
  const level = enable ? 3 : 0
  const callback = new (class implements TUICommonDefine.Callback {
    override onSuccess() {
    }
    override onError(code: Int, message: String) {
      console.log(`setVirtualBackground failed, errorCode: ${code}, message: ${message}`);
    }
  });
  TUICallEngine.createInstance(context).setBlurBackground(level, callback)
}

/**
 * 开启/关闭 TUICallEngine 的多设备登录模式
 */
export function enableMultiDeviceAbility(enable: Boolean) {
  const callback = new (class implements TUICommonDefine.Callback {
    override onSuccess() {
    }
    override onError(code: Int, message: String) {
      console.log(`setVirtualBackground failed, errorCode: ${code}, message: ${message}`);
    }
  });
  TUICallEngine.createInstance(context).enableMultiDeviceAbility(enable, callback)
}

// ================= ImageUploader: pickSingleImageFromAlbum ====================

UTSAndroid.onAppActivityResult((requestCode: Int, resultCode: Int, data?: Intent) => {
  const activity = UTSAndroid.getUniActivity();
  if (activity != null) {
    SystemImagePicker.onActivityResult(activity!, requestCode, resultCode, data);
  }
});

@UTSJS.keepAlive
export function pickSingleImageFromAlbum(
  onSuccess: (tempFilePath: string) => void,
  onCancel: () => void
): void {
  const activity = UTSAndroid.getUniActivity();
  if (activity == null) {
    onCancel();
    return;
  }
  SystemImagePicker.pickSingleImage(activity!, onSuccess, onCancel);
}

