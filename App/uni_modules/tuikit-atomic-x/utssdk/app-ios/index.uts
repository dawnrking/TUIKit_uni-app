// ================= ImageUploader: pickSingleImageFromAlbum ====================

@UTSJS.keepAlive
export function pickSingleImageFromAlbum(
  onSuccess: (tempFilePath: string) => void,
  onCancel: () => void
): void {
  SystemImagePicker.shared.pickSingleImage(
    onSuccess = (filePath: string): void => {
      onSuccess(filePath);
    },
    onCancel = (): void => {
      onCancel();
    }
  );
}

// ================= LogUpload: 日志导出 ====================

/**
 * 获取日志文件列表
 * @returns 日志文件列表 JSON 字符串，格式: [{ "fileName": string, "filePath": string }]
 */
export function fetchLogFileList(): string {
  const fileModels = LogUpload.shared.fetchLogfileList()
  let result: UTSJSONObject[] = []
  for (let i = 0; i < Int(fileModels.count); i++) {
    const model = fileModels[Int(i)]
    const item: UTSJSONObject = { "fileName": model.fileName, "filePath": model.filePath }
    result.push(item)
  }
  return JSON.stringify(result) ?? "[]"
}

/**
 * 分享指定索引的日志文件（弹出系统分享面板）
 * @param row 日志文件在列表中的索引
 */
export function shareLog(row: number) {
  DispatchQueue.main.async(execute = (): void => {
    console.log("shareLog called, row:", row)
    LogUpload.shared.shareLog(Int(row))
  })
}